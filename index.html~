<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Haley’s Cleaning Services | Modern & Reliable Cleaning</title>
    <!-- Link to the compiled Tailwind CSS output -->
    <link href="./dist/output.css" rel="stylesheet">
</head>
<body class="bg-nude-light text-gray-800 font-sans antialiased selection:bg-sage selection:text-white">

    <!-- Navigation -->
    <header class="bg-white/80 backdrop-blur-md sticky top-0 z-50 border-b border-nude">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="#" class="text-xl font-semibold tracking-tight text-sage-dark">
                Haley’s <span class="font-light">Cleaning Services</span>
            </a>
            <nav class="hidden md:flex space-x-8 text-sm font-medium text-gray-600">
                <a href="#" class="text-sage-dark font-semibold">Home</a>
                <a href="services.html" class="hover:text-sage transition">Services</a>
                <a href="portfolio.html" class="hover:text-sage transition">Portfolio</a>
                <a href="reviews.html" class="hover:text-sage transition">Reviews</a>
                <a href="#contact" class="hover:text-sage transition">Contact</a>
            </nav>
            <a href="#contact" class="bg-sage hover:bg-sage-dark text-white text-sm font-medium px-5 py-2.5 rounded-full transition shadow-sm">
                Get a Free Quote
            </a>
        </div>
    </header>

    <!-- Hero Section -->
    <section class="max-w-6xl mx-auto px-6 py-20 md:py-32 flex flex-col items-center text-center">
        <span class="bg-nude border border-nude-dark/40 text-sage-dark text-xs uppercase tracking-widest font-semibold px-4 py-1.5 rounded-full mb-6">
            Trusted Residential & Commercial Cleaning
        </span>
        <h1 class="text-4xl md:text-6xl font-light tracking-tight text-gray-900 max-w-3xl leading-tight">
            A spotless space, <span class="font-semibold text-sage-dark">simplified.</span>
        </h1>
        <p class="mt-6 text-lg text-gray-600 max-w-xl font-light leading-relaxed">
            Professional one-time, recurring, deep cleaning, and commercial services tailored to your schedule. We handle the mess so you don't have to.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <a href="#contact" class="bg-sage hover:bg-sage-dark text-white font-medium px-8 py-3.5 rounded-full transition shadow-md text-center">
                Request Your Quote
            </a>
            <a href="#services" class="bg-white hover:bg-nude text-gray-700 border border-nude-dark font-medium px-8 py-3.5 rounded-full transition text-center">
                Explore Services
            </a>
        </div>
    </section>

    <!-- Core Services Grid -->
    <section id="services" class="bg-white py-24 border-y border-nude">
        <div class="max-w-6xl mx-auto px-6">
            <div class="text-center max-w-2xl mx-auto mb-16">
                <h2 class="text-3xl font-light tracking-tight text-gray-900">Comprehensive Cleaning Solutions</h2>
                <p class="mt-3 text-gray-500 text-sm">Designed around your home, rental, or business needs.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Service 1 -->
                <div class="bg-nude-light p-8 rounded-2xl border border-nude hover:shadow-lg transition">
                    <div class="w-10 h-10 bg-sage/20 rounded-full flex items-center justify-center text-sage-dark font-bold mb-6">✨</div>
                    <h3 class="text-xl font-semibold text-gray-800">Recurring Routine Cleans</h3>
                    <p class="mt-3 text-gray-600 text-sm leading-relaxed">
                        Flexible scheduling options including weekly, bi-weekly, or monthly cleaning to maintain a consistently pristine environment.
                    </p>
                </div>

                <!-- Service 2 -->
                <div class="bg-nude-light p-8 rounded-2xl border border-nude hover:shadow-lg transition">
                    <div class="w-10 h-10 bg-sage/20 rounded-full flex items-center justify-center text-sage-dark font-bold mb-6">🏡</div>
                    <h3 class="text-xl font-semibold text-gray-800">Deep & Move-In/Out Cleans</h3>
                    <p class="mt-3 text-gray-600 text-sm leading-relaxed">
                        Intensive top-to-bottom sanitization perfect for revitalizing a space, prepping for new tenants, or clearing out after a move.
                    </p>
                </div>

                <!-- Service 3 -->
                <div class="bg-nude-light p-8 rounded-2xl border border-nude hover:shadow-lg transition">
                    <div class="w-10 h-10 bg-sage/20 rounded-full flex items-center justify-center text-sage-dark font-bold mb-6">🏢</div>
                    <h3 class="text-xl font-semibold text-gray-800">Commercial & Rentals</h3>
                    <p class="mt-3 text-gray-600 text-sm leading-relaxed">
                        Reliable turnover cleaning for rentals and detailed care for local commercial spaces, ensuring professional first impressions.
                    </p>
                </div>
            </div>
            <div class="mt-12 text-center">
                <p class="text-sm text-gray-500">Need laundry services or specialized add-ons? <a href="#contact" class="text-sage-dark underline font-medium">Let us know in your quote request.</a></p>
            </div>
        </div>
    </section>

    <!-- Credibility / CTA Banner -->
    <section class="bg-sage text-white py-20">
        <div class="max-w-4xl mx-auto px-6 text-center">
            <h2 class="text-3xl font-light">Ready to experience a truly clean space?</h2>
            <p class="mt-4 text-sage-light max-w-xl mx-auto text-sm font-light leading-relaxed text-white/90">
                Contact us today for a transparent, no-obligation quote tailored specifically to the square footage and demands of your property.
            </p>
            <div class="mt-8">
                <a href="#contact" class="bg-white text-sage-dark hover:bg-nude-light font-semibold px-8 py-3.5 rounded-full transition inline-block shadow-sm">
                    Get in Touch
                </a>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-nude-light py-12 border-t border-nude">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6 text-sm text-gray-600">
            <div>
                <span class="font-semibold text-gray-800">Haley’s Cleaning Services</span>
                <p class="text-xs text-gray-500 mt-1">Professional residential and commercial cleaning.</p>
            </div>
            <div class="flex gap-6 text-xs font-medium">
                <span>📞 (229) 400-1876</span>
                <span>✉️ haleyanngreen@yahoo.com</span>
            </div>
            <div class="text-xs text-gray-400">
                &copy; 2026 Haley’s Cleaning Services. All rights reserved.
            </div>
        </div>
    </footer>

</body>
</html>
